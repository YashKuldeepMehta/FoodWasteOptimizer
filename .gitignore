# Ignore node_modules in both frontend and backend
/frontend/node_modules/
/backend/node_modules/

# Ignore build folder (React production build)
frontend/build/

# Ignore environment files
.env
.env.local
frontend/.env
backend/.env

# Ignore logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignore system files
.DS_Store
Thumbs.db

# Ignore IDE/editor files
.vscode/
*.swp
.idea/

# Optional: ignore MongoDB data dump
dump/
